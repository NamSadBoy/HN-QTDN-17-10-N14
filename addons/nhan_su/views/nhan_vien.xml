<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.nhan_su</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Lương &amp; Bảo hiểm" name="luong_bao_hiem">
                    <group>
                        <group string="Cấu hình Lương">
                            <field name="he_so_luong"/>
                            <field name="luong_co_ban"/>
                        </group>
                        <group string="Cấu hình Bảo hiểm">
                            <field name="tham_gia_bao_hiem"/>
                            <field name="so_so_bhxh" attrs="{'invisible': [('tham_gia_bao_hiem', '=', False)]}"/>
                            <field name="muc_luong_dong_bao_hiem" attrs="{'invisible': [('tham_gia_bao_hiem', '=', False)]}"/>
                        </group>
                    </group>
                </page>
                <page string="Lịch sử công tác" name="lich_su_cong_tac">
                    <field name="lich_su_cong_tac_ids">
                        <tree editable="bottom">
                            <field name="tu_ngay"/>
                            <field name="den_ngay"/>
                            <field name="phong_ban_id"/>
                            <field name="chuc_vu_id"/>
                            <field name="ghi_chu"/>
                        </tree>
                    </field>
                </page>
                <page string="Bằng cấp &amp; Chứng chỉ" name="bang_cap">
                    <field name="bang_cap_ids">
                        <tree editable="bottom">
                            <field name="bang_cap_id"/>
                            <field name="ngay_cap"/>
                            <field name="noi_cap"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>