<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bang_cap_tree" model="ir.ui.view">
        <field name="name">nhan_su.bang_cap.tree</field>
        <field name="model">nhan_su.bang_cap</field>
        <field name="arch" type="xml">
            <tree string="Danh mục Bằng cấp">
                <field name="code"/>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="action_danh_muc_bang_cap" model="ir.actions.act_window">
        <field name="name">Danh mục Bằng cấp</field>
        <field name="res_model">nhan_su.bang_cap</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>